# =============================================================
# VígiSUS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).
# =============================================================

# -------------------------------------------------------------
# Banco de dados PostgreSQL
# -------------------------------------------------------------
# Nome do banco, usuário e senha
DB_NAME=vigisus
DB_USER=vigisus
DB_PASS=vigisus123
DB_PORT=5432

# URL JDBC completa usada pelo backend Spring Boot e pelo data-pipeline.
# Localmente (sem Docker): aponta para localhost.
# Dentro do Docker Compose: o host deve ser o nome do serviço "postgres".
DB_URL=jdbc:postgresql://localhost:5432/vigisus

# -------------------------------------------------------------
# Inteligência Artificial (OpenAI)
# -------------------------------------------------------------
# Chave de API da OpenAI — obrigatória para o módulo de IA funcionar.
OPENAI_API_KEY=sk-sua-chave-aqui

# Modelo a ser utilizado (padrão: gpt-4o-mini)
VIGISUS_IA_MODEL=gpt-4o-mini

# Endpoint da API (altere apenas se usar um proxy ou outro provider)
VIGISUS_IA_URL=https://api.openai.com/v1/chat/completions

# -------------------------------------------------------------
# Frontend (React)
# -------------------------------------------------------------
# URL do backend acessível pelo navegador do usuário final.
# Em produção, substitua pelo endereço público do backend.
REACT_APP_API_URL=http://localhost:8080

# -------------------------------------------------------------
# Data Pipeline (Python)
# -------------------------------------------------------------
# Unidade Federativa padrão para importação de dados (sigla de 2 letras)
UF=MG

# Competência padrão no formato AAAAMM (ex.: 2502 = fevereiro/2025)
COMPETENCIA=2502
